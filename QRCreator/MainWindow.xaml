<ui:FluentWindow
    x:Class="QRCreator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:QRCreator.Converters"
    xmlns:models="clr-namespace:QRCreator.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="QR Creator"
    Width="1100"
    Height="750"
    MinWidth="800"
    MinHeight="600"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBool" />
        <converters:ColorToHexConverter x:Key="ColorToHex" />
        <converters:IntToBooleanConverter x:Key="IntToBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--  Shape icon geometries  -->
        <Geometry x:Key="SquareGeom">M2,2 H14 V14 H2 Z</Geometry>
        <Geometry x:Key="CircleGeom">M8,1 A7,7 0 1,0 8,15 A7,7 0 1,0 8,1 Z</Geometry>
        <Geometry x:Key="RoundedSquareGeom">M5,2 H11 A3,3 0 0,1 14,5 V11 A3,3 0 0,1 11,14 H5 A3,3 0 0,1 2,11 V5 A3,3 0 0,1 5,2 Z</Geometry>
        <Geometry x:Key="DiamondGeom">M8,1 L15,8 L8,15 L1,8 Z</Geometry>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Title Bar with Theme Toggle  -->
        <ui:TitleBar Title="QR Creator" Grid.Row="0">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:Button
                        x:Name="ThemeToggleButton"
                        Appearance="Transparent"
                        Click="ThemeToggle_Click"
                        Icon="{ui:SymbolIcon WeatherMoon24}"
                        ToolTip="Toggle Theme" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!--  Main Content: 2-column layout  -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  LEFT: Options Panel  -->
            <ScrollViewer
                Grid.Column="0"
                Padding="16,8,8,16"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!--  URL Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="URL" />
                            <ui:TextBox PlaceholderText="Enter URL or text..." Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:Card>

                    <!--  Cell Shape Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="Cell Shape" />
                            <UniformGrid HorizontalAlignment="Stretch" Columns="4">
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding CellShape, Converter={StaticResource EnumToBool}, ConverterParameter=Square}"
                                    ToolTip="Square">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource SquareGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding CellShape, Converter={StaticResource EnumToBool}, ConverterParameter=Circle}"
                                    ToolTip="Circle">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource CircleGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding CellShape, Converter={StaticResource EnumToBool}, ConverterParameter=RoundedSquare}"
                                    ToolTip="Rounded">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource RoundedSquareGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding CellShape, Converter={StaticResource EnumToBool}, ConverterParameter=Diamond}"
                                    ToolTip="Diamond">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource DiamondGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                            </UniformGrid>
                        </StackPanel>
                    </ui:Card>

                    <!--  Finder Shape Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="Finder Shape" />
                            <UniformGrid
                                Width="210"
                                HorizontalAlignment="Left"
                                Columns="3">
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding FinderShape, Converter={StaticResource EnumToBool}, ConverterParameter=Square}"
                                    ToolTip="Square">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource SquareGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding FinderShape, Converter={StaticResource EnumToBool}, ConverterParameter=Circle}"
                                    ToolTip="Circle">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource CircleGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                                <ToggleButton
                                    Margin="2"
                                    IsChecked="{Binding FinderShape, Converter={StaticResource EnumToBool}, ConverterParameter=RoundedSquare}"
                                    ToolTip="Rounded">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource RoundedSquareGeom}"
                                        Fill="{DynamicResource TextFillColorPrimaryBrush}"
                                        Stretch="Uniform" />
                                </ToggleButton>
                            </UniformGrid>
                        </StackPanel>
                    </ui:Card>

                    <!--  Colors Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,12"
                                FontWeight="SemiBold"
                                Text="Colors" />

                            <!--  Foreground Color  -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="12"
                                    Opacity="0.7"
                                    Text="Foreground" />
                                <DockPanel Margin="0,0,0,4">
                                    <Rectangle
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Stroke="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        StrokeThickness="1">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="{Binding ForegroundColor}" />
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <ui:TextBox
                                        Width="90"
                                        HorizontalAlignment="Left"
                                        MaxLength="7"
                                        Text="{Binding ForegroundColor, Converter={StaticResource ColorToHex}, UpdateSourceTrigger=LostFocus}" />
                                </DockPanel>
                                <UniformGrid
                                    Width="210"
                                    HorizontalAlignment="Left"
                                    Columns="6">
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF000000"
                                        Click="FgColorPreset_Click"
                                        Tag="#000000"
                                        ToolTip="#000000" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFFFFFFF"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Click="FgColorPreset_Click"
                                        Tag="#FFFFFF"
                                        ToolTip="#FFFFFF" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFE53935"
                                        Click="FgColorPreset_Click"
                                        Tag="#E53935"
                                        ToolTip="#E53935" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFE91E63"
                                        Click="FgColorPreset_Click"
                                        Tag="#E91E63"
                                        ToolTip="#E91E63" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF9C27B0"
                                        Click="FgColorPreset_Click"
                                        Tag="#9C27B0"
                                        ToolTip="#9C27B0" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF673AB7"
                                        Click="FgColorPreset_Click"
                                        Tag="#673AB7"
                                        ToolTip="#673AB7" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF1E88E5"
                                        Click="FgColorPreset_Click"
                                        Tag="#1E88E5"
                                        ToolTip="#1E88E5" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF00ACC1"
                                        Click="FgColorPreset_Click"
                                        Tag="#00ACC1"
                                        ToolTip="#00ACC1" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF43A047"
                                        Click="FgColorPreset_Click"
                                        Tag="#43A047"
                                        ToolTip="#43A047" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF7CB342"
                                        Click="FgColorPreset_Click"
                                        Tag="#7CB342"
                                        ToolTip="#7CB342" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFFB8C00"
                                        Click="FgColorPreset_Click"
                                        Tag="#FB8C00"
                                        ToolTip="#FB8C00" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF795548"
                                        Click="FgColorPreset_Click"
                                        Tag="#795548"
                                        ToolTip="#795548" />
                                </UniformGrid>
                            </StackPanel>

                            <!--  Background Color  -->
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="12"
                                    Opacity="0.7"
                                    Text="Background" />
                                <DockPanel Margin="0,0,0,4">
                                    <Rectangle
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Stroke="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        StrokeThickness="1">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="{Binding BackgroundColor}" />
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <ui:TextBox
                                        Width="90"
                                        HorizontalAlignment="Left"
                                        MaxLength="7"
                                        Text="{Binding BackgroundColor, Converter={StaticResource ColorToHex}, UpdateSourceTrigger=LostFocus}" />
                                </DockPanel>
                                <UniformGrid
                                    Width="210"
                                    HorizontalAlignment="Left"
                                    Columns="6">
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF000000"
                                        Click="BgColorPreset_Click"
                                        Tag="#000000"
                                        ToolTip="#000000" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFFFFFFF"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Click="BgColorPreset_Click"
                                        Tag="#FFFFFF"
                                        ToolTip="#FFFFFF" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFE53935"
                                        Click="BgColorPreset_Click"
                                        Tag="#E53935"
                                        ToolTip="#E53935" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFE91E63"
                                        Click="BgColorPreset_Click"
                                        Tag="#E91E63"
                                        ToolTip="#E91E63" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF9C27B0"
                                        Click="BgColorPreset_Click"
                                        Tag="#9C27B0"
                                        ToolTip="#9C27B0" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF673AB7"
                                        Click="BgColorPreset_Click"
                                        Tag="#673AB7"
                                        ToolTip="#673AB7" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF1E88E5"
                                        Click="BgColorPreset_Click"
                                        Tag="#1E88E5"
                                        ToolTip="#1E88E5" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF00ACC1"
                                        Click="BgColorPreset_Click"
                                        Tag="#00ACC1"
                                        ToolTip="#00ACC1" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF43A047"
                                        Click="BgColorPreset_Click"
                                        Tag="#43A047"
                                        ToolTip="#43A047" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF7CB342"
                                        Click="BgColorPreset_Click"
                                        Tag="#7CB342"
                                        ToolTip="#7CB342" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FFFB8C00"
                                        Click="BgColorPreset_Click"
                                        Tag="#FB8C00"
                                        ToolTip="#FB8C00" />
                                    <Button
                                        Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="#FF795548"
                                        Click="BgColorPreset_Click"
                                        Tag="#795548"
                                        ToolTip="#795548" />
                                </UniformGrid>
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <!--  Size Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="Size" />
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock
                                    Width="70"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    Text="Cell Size" />
                                <TextBlock
                                    Width="30"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Right"
                                    Text="{Binding CellSize}"
                                    TextAlignment="Right" />
                                <Slider
                                    IsSnapToTickEnabled="True"
                                    Maximum="30"
                                    Minimum="5"
                                    TickFrequency="1"
                                    Value="{Binding CellSize}" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock
                                    Width="70"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    Text="Cell Gap" />
                                <TextBlock
                                    Width="30"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Right"
                                    Text="{Binding CellGap}"
                                    TextAlignment="Right" />
                                <Slider
                                    IsSnapToTickEnabled="True"
                                    Maximum="5"
                                    Minimum="0"
                                    TickFrequency="1"
                                    Value="{Binding CellGap}" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!--  Logo Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="Logo" />
                            <DockPanel>
                                <ui:Button
                                    Margin="0,0,8,0"
                                    Command="{Binding SelectLogoCommand}"
                                    Content="Select..."
                                    DockPanel.Dock="Left" />
                                <ui:Button
                                    Width="32"
                                    Margin="8,0,0,0"
                                    Appearance="Danger"
                                    Command="{Binding RemoveLogoCommand}"
                                    Content="X"
                                    DockPanel.Dock="Right"
                                    Visibility="{Binding LogoPath, Converter={StaticResource BoolToVis}, TargetNullValue=Collapsed}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Opacity="0.7"
                                    Text="{Binding LogoPath, TargetNullValue='No logo selected'}"
                                    TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <DockPanel Margin="0,8,0,0" Visibility="{Binding LogoPath, Converter={StaticResource BoolToVis}, TargetNullValue=Collapsed}">
                                <TextBlock
                                    Width="70"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    Text="Logo Size" />
                                <TextBlock
                                    Width="40"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Right"
                                    Text="{Binding LogoSizeRatio, StringFormat={}{0:P0}}"
                                    TextAlignment="Right" />
                                <Slider
                                    IsSnapToTickEnabled="True"
                                    Maximum="0.3"
                                    Minimum="0.05"
                                    TickFrequency="0.05"
                                    Value="{Binding LogoSizeRatio}" />
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>

                    <!--  Export Card  -->
                    <ui:Card Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="Export" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Text="Scale:" />
                                <ToggleButton
                                    MinWidth="48"
                                    Margin="0,0,4,0"
                                    Content="1x"
                                    IsChecked="{Binding ExportScale, Converter={StaticResource IntToBool}, ConverterParameter=1}" />
                                <ToggleButton
                                    MinWidth="48"
                                    Margin="0,0,4,0"
                                    Content="2x"
                                    IsChecked="{Binding ExportScale, Converter={StaticResource IntToBool}, ConverterParameter=2}" />
                                <ToggleButton
                                    MinWidth="48"
                                    Content="4x"
                                    IsChecked="{Binding ExportScale, Converter={StaticResource IntToBool}, ConverterParameter=4}" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                </StackPanel>
            </ScrollViewer>

            <!--  RIGHT: Preview Panel  -->
            <Grid Grid.Column="1" Margin="8,8,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  InfoBar for errors  -->
                <ui:InfoBar
                    Title="Error"
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    IsOpen="{Binding HasError}"
                    Message="{Binding ErrorMessage}"
                    Severity="Warning" />

                <!--  QR Preview  -->
                <Border
                    Grid.Row="1"
                    Padding="16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Image
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="{Binding PreviewBitmap}"
                        Stretch="Uniform" />
                </Border>

                <!--  Action Buttons  -->
                <StackPanel
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Appearance="Primary"
                        Command="{Binding SavePngCommand}"
                        Content="Save PNG"
                        Icon="{ui:SymbolIcon Save24}" />
                    <ui:Button
                        Command="{Binding CopyToClipboardCommand}"
                        Content="Copy"
                        Icon="{ui:SymbolIcon Copy24}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
