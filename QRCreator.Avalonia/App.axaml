<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QRCreator.Avalonia.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppCardBrush" Color="#2D2D2D" />
                    <SolidColorBrush x:Key="AppPreviewBgBrush" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="AppTitleBarBrush" Color="#202020" />
                    <SolidColorBrush x:Key="AppStrokeBrush" Color="#444444" />
                    <SolidColorBrush x:Key="AppIconFillBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppPaletteBorderBrush" Color="#555555" />
                    <SolidColorBrush x:Key="AppErrorBgBrush" Color="#4D2600" />
                    <SolidColorBrush x:Key="AppErrorFgBrush" Color="#FFB74D" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppCardBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppPreviewBgBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="AppTitleBarBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="AppStrokeBrush" Color="#D0D0D0" />
                    <SolidColorBrush x:Key="AppIconFillBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="AppPaletteBorderBrush" Color="#CCCCCC" />
                    <SolidColorBrush x:Key="AppErrorBgBrush" Color="#FFF3E0" />
                    <SolidColorBrush x:Key="AppErrorFgBrush" Color="#E65100" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
